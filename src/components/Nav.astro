---
const links = [
  { label: 'Our Story',       href: '#story'       },
  { label: 'The Menu',        href: '#menu'         },
  { label: 'Gallery',         href: '#gallery'      },
  { label: 'Reserve a Table', href: '#reservation'  },
]
---

<nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-5 flex items-center justify-between nav-bar">
  <!-- Logo -->
  <a href="/" class="font-serif italic text-cream text-lg tracking-wide leading-none hover:text-warm-beige transition-colors duration-300">
    The Secret Cottage Café
  </a>

  <!-- Desktop links -->
  <ul class="hidden md:flex items-center gap-10">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="font-sans text-sm font-light text-cream/80 tracking-widest uppercase hover:text-rose-clay transition-colors duration-300 nav-link"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile: just the reserve link -->
  <a
    href="#reservation"
    class="md:hidden font-sans text-xs tracking-widest uppercase text-cream/70 hover:text-rose-clay transition-colors duration-300"
  >
    Reserve
  </a>
</nav>

<style>
  .nav-bar {
    background: linear-gradient(
      to bottom,
      rgba(36, 26, 20, 0.6) 0%,
      rgba(36, 26, 20, 0) 100%
    );
  }

  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: #C98F7A;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
