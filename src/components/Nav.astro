---
const links = [
  { label: 'Our Story',       href: '#story'       },
  { label: 'The Menu',        href: '#menu'         },
  { label: 'Gallery',         href: '#gallery'      },
  { label: 'Reserve a Table', href: '#reservation'  },
]
---

<nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-5 flex items-center justify-between nav-bar">

  <!-- Logo -->
  <a href="/" class="font-serif italic text-cream text-lg tracking-wide leading-none hover:text-warm-beige transition-colors duration-300 relative z-50">
    The Secret Cottage Café
  </a>

  <!-- Desktop links -->
  <ul class="hidden md:flex items-center gap-10">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="font-sans text-sm font-light text-cream/80 tracking-widest uppercase hover:text-rose-clay transition-colors duration-300 nav-link"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile hamburger — CSS-only via <details> -->
  <details class="md:hidden mobile-details">
    <summary class="mobile-summary relative z-50" aria-label="Toggle navigation menu">
      <span class="hamburger" aria-hidden="true">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </span>
    </summary>

    <!-- Full-screen overlay -->
    <div class="mobile-overlay" role="dialog" aria-label="Navigation menu">
      <ul class="flex flex-col items-center gap-10">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-serif italic text-cream text-3xl font-normal hover:text-soft-sage transition-colors duration-300 mobile-nav-link"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <p class="font-accent text-soft-sage/60 text-xl mt-16">
        Follow the warmth.
      </p>
    </div>
  </details>

</nav>

<style>
  .nav-bar {
    background: linear-gradient(
      to bottom,
      rgba(36, 26, 20, 0.65) 0%,
      rgba(36, 26, 20, 0) 100%
    );
  }

  /* Desktop link underline */
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: #C98F7A;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* ─── Mobile ─────────────────────────────────────────────────────────── */

  /* Hide default marker */
  .mobile-summary { list-style: none; cursor: pointer; }
  .mobile-summary::-webkit-details-marker { display: none; }

  /* Hamburger bars */
  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }
  .bar {
    display: block;
    height: 1.5px;
    background: #F5EFE6;
    border-radius: 1px;
    transform-origin: center;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  /* Animate bars to X when open */
  .mobile-details[open] .bar:nth-child(1) {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  .mobile-details[open] .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-details[open] .bar:nth-child(3) {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }

  /* Full-screen overlay */
  .mobile-overlay {
    display: none;
  }
  .mobile-details[open] .mobile-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: fixed;
    inset: 0;
    background: #3F5D45;
    z-index: 40;
    padding: 2rem;
  }

  /* Mobile nav link underline */
  .mobile-nav-link {
    position: relative;
    display: inline-block;
  }
  .mobile-nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: #A7B89A;
    transition: width 0.35s ease;
  }
  .mobile-nav-link:hover::after {
    width: 100%;
  }
</style>
