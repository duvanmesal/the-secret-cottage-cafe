---
---

<section id="garden-path" class="relative overflow-hidden garden-bg">

  <!-- CSS garden scene — replaced by GSAP parallax layers later -->
  <div class="relative w-full garden-scene" aria-hidden="true">

    <!-- Sky layer -->
    <div class="absolute inset-0 garden-sky"></div>

    <!-- Far tree line -->
    <div class="absolute bottom-0 left-0 right-0 garden-treeline"></div>

    <!-- Mid hedge row -->
    <div class="absolute bottom-0 left-0 right-0 garden-hedges"></div>

    <!-- Path -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 garden-path-strip"></div>

    <!-- Foreground flowers — left -->
    <div class="absolute bottom-4 left-0 w-1/3 h-32 flex items-end gap-2 px-8">
      {Array.from({ length: 6 }).map((_, i) => (
        <div
          class="garden-flower"
          style={`height: ${48 + (i % 3) * 18}px; opacity: ${0.6 + (i % 2) * 0.2}`}
        />
      ))}
    </div>

    <!-- Foreground flowers — right -->
    <div class="absolute bottom-4 right-0 w-1/3 h-32 flex items-end justify-end gap-2 px-8">
      {Array.from({ length: 6 }).map((_, i) => (
        <div
          class="garden-flower garden-flower--rose"
          style={`height: ${42 + (i % 4) * 14}px; opacity: ${0.5 + (i % 3) * 0.15}`}
        />
      ))}
    </div>

    <!-- Parallax placeholder label -->
    <span class="absolute top-4 left-1/2 -translate-x-1/2 font-sans text-xs text-coffee-brown/25 tracking-widest uppercase">
      GSAP Parallax Layers
    </span>
  </div>

  <!-- Text content -->
  <div class="relative z-10 max-w-2xl mx-auto px-6 py-24 md:py-32 text-center">

    <h2 class="font-serif italic text-coffee-brown text-3xl md:text-5xl font-normal leading-snug mb-8">
      The garden wakes<br />before anyone else.
    </h2>

    <div class="divider-warm mx-auto mb-8" aria-hidden="true"></div>

    <p class="font-sans font-light text-dark-espresso/70 text-lg leading-relaxed max-w-md mx-auto">
      Mornings here begin with dew on the roses and the first kettle
      of the day. The path to our door is always open.
    </p>

  </div>

</section>

<style>
  .garden-bg {
    background: linear-gradient(180deg, #1a120d 0%, #2c3828 15%, #A7B89A 60%, #F5EFE6 100%);
  }

  .garden-scene {
    height: clamp(260px, 38vw, 460px);
  }

  .garden-sky {
    background: linear-gradient(180deg, #1a120d 0%, #2d3d28 30%, #4a6040 60%, #A7B89A 100%);
  }

  .garden-treeline {
    height: 55%;
    background: linear-gradient(
      180deg,
      transparent 0%,
      #2c3a24 20%,
      #3F5D45 60%,
      #344e38 100%
    );
    clip-path: polygon(
      0% 100%, 0% 45%, 3% 30%, 6% 20%, 8% 8%, 11% 18%, 14% 5%,
      17% 15%, 20% 2%, 23% 14%, 26% 0%, 29% 12%, 32% 4%, 35% 16%,
      38% 2%, 41% 14%, 44% 3%, 47% 12%, 50% 0%, 53% 10%, 56% 3%,
      59% 14%, 62% 2%, 65% 12%, 68% 4%, 71% 15%, 74% 2%, 77% 14%,
      80% 5%, 83% 16%, 86% 4%, 89% 18%, 92% 8%, 95% 20%, 97% 10%,
      100% 30%, 100% 100%
    );
  }

  .garden-hedges {
    height: 35%;
    background: linear-gradient(180deg, #4a6540 0%, #3F5D45 50%, #2e4832 100%);
    clip-path: polygon(
      0% 100%, 0% 40%, 4% 25%, 8% 10%, 12% 22%, 16% 8%, 20% 20%,
      24% 35%, 28% 15%, 32% 28%, 36% 18%, 40% 32%,
      /* path opening */
      40% 100%, 60% 100%,
      60% 32%, 64% 18%, 68% 28%, 72% 15%, 76% 35%,
      80% 20%, 84% 8%, 88% 22%, 92% 10%, 96% 25%, 100% 40%, 100% 100%
    );
  }

  .garden-path-strip {
    width: 20%;
    min-width: 80px;
    height: 35%;
    background: linear-gradient(
      180deg,
      #6b5a48 0%,
      #8c7260 30%,
      #D8C3A5 100%
    );
    clip-path: polygon(20% 0%, 80% 0%, 100% 100%, 0% 100%);
    bottom: 0;
  }

  .garden-flower {
    width: 6px;
    background: linear-gradient(180deg, #A7B89A 0%, #3F5D45 100%);
    border-radius: 3px;
    position: relative;
  }
  .garden-flower::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #D8C3A5;
  }

  .garden-flower--rose::before {
    background: #C98F7A;
  }
</style>
