---
import { seasonalItems } from '../data/seasonalItems'

const autumn = seasonalItems.find(s => s.season === 'autumn')!
---

<section id="seasonal-garden" class="relative overflow-hidden seasonal-bg">

  <!-- Background texture layer -->
  <div class="absolute inset-0 seasonal-texture pointer-events-none" aria-hidden="true"></div>

  <!-- Falling leaves placeholder — R3F PetalEffect will go here -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    {Array.from({ length: 8 }).map((_, i) => (
      <div
        class="leaf"
        style={`
          left: ${10 + i * 11}%;
          animation-delay: ${i * 0.6}s;
          animation-duration: ${5 + (i % 3)}s;
        `}
      />
    ))}
    <span class="absolute top-6 right-6 font-sans text-xs text-cream/20 tracking-widest uppercase">
      R3F Petal Effect
    </span>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-12 py-28 md:py-40">

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Left: text -->
      <div data-seasonal-left>
        <p class="font-sans text-xs tracking-[0.2em] uppercase text-soft-sage mb-8">
          Autumn · 2025
        </p>

        <h2 class="font-serif italic text-cream text-4xl md:text-6xl font-normal leading-tight mb-8">
          Autumn in<br />the Garden
        </h2>

        <div class="w-10 h-px bg-soft-sage/50 mb-8" aria-hidden="true"></div>

        <p class="font-sans font-light text-cream/70 text-lg leading-relaxed max-w-sm mb-12">
          The hedges have turned. The apples are falling. And the kitchen smells
          of warm spice and dark caramel from before sunrise.
        </p>

        <p class="font-accent text-rose-clay text-2xl">Gone when the season is.</p>
      </div>

      <!-- Right: featured drink card -->
      <div data-seasonal-right class="relative">
        <article class="seasonal-card p-8 md:p-10 relative overflow-hidden">

          <!-- Card grain overlay -->
          <div class="absolute inset-0 card-texture pointer-events-none" aria-hidden="true"></div>

          <!-- Corner marks -->
          <div class="absolute top-5 left-5 w-4 h-4 border-t border-l border-cream/20" aria-hidden="true"></div>
          <div class="absolute top-5 right-5 w-4 h-4 border-t border-r border-cream/20" aria-hidden="true"></div>

          <div class="relative z-10">
            <p class="font-sans text-xs tracking-[0.2em] uppercase text-soft-sage/70 mb-5">
              Featured this season
            </p>

            <h3 class="font-serif text-cream text-3xl md:text-4xl font-normal leading-tight mb-4">
              {autumn.name}
            </h3>

            <p class="font-sans font-light text-cream/60 text-base leading-relaxed mb-8">
              {autumn.description}
            </p>

            <!-- Ingredients -->
            <div class="flex flex-wrap gap-2 mb-8">
              {autumn.notes.map(note => (
                <span class="font-sans text-xs text-cream/50 tracking-wider uppercase border border-cream/15 rounded-full px-3 py-1">
                  {note}
                </span>
              ))}
            </div>

            <!-- Availability -->
            <div class="flex items-center gap-3 pt-6 border-t border-cream/10">
              <div class="w-2 h-2 rounded-full bg-rose-clay flex-shrink-0"></div>
              <p class="font-sans text-sm text-cream/50">
                Available {autumn.available}
              </p>
            </div>
          </div>

        </article>

        <!-- Decorative shadow element -->
        <div class="seasonal-card-shadow absolute inset-0 -z-10 translate-x-3 translate-y-3" aria-hidden="true"></div>
      </div>

    </div>

  </div>

</section>

<style>
  .seasonal-bg {
    background: linear-gradient(
      135deg,
      #1e2c1a 0%,
      #2d3f28 25%,
      #3F5D45 55%,
      #2e3d25 100%
    );
  }

  .seasonal-texture {
    background-image: radial-gradient(
      ellipse 80% 60% at 10% 80%,
      rgba(90, 62, 43, 0.2) 0%,
      transparent 60%
    ),
    radial-gradient(
      ellipse 50% 40% at 90% 20%,
      rgba(201, 143, 122, 0.08) 0%,
      transparent 60%
    );
  }

  .seasonal-card {
    background: rgba(36, 26, 20, 0.55);
    border: 1px solid rgba(245, 239, 230, 0.10);
    border-radius: 4px;
    backdrop-filter: blur(8px);
  }

  .seasonal-card-shadow {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
  }

  .card-texture {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.03;
  }

  /* CSS leaf animation as R3F placeholder */
  .leaf {
    position: absolute;
    top: -20px;
    width: 10px;
    height: 14px;
    background: linear-gradient(135deg, #C98F7A 0%, #5A3E2B 100%);
    border-radius: 0 50% 0 50%;
    opacity: 0.5;
    animation: leaf-fall linear infinite;
  }

  @keyframes leaf-fall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 0; }
    10%  { opacity: 0.5; }
    90%  { opacity: 0.3; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .leaf { animation: none; opacity: 0; }
  }
</style>
