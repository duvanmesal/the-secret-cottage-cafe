---
---

<section id="cottage-entrance" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden entrance-bg">

  <!-- Warm emanating glow from door -->
  <div class="absolute inset-0 door-glow pointer-events-none" aria-hidden="true"></div>

  <!-- CSS Door -->
  <div class="relative z-10 flex flex-col items-center mb-16" aria-hidden="true">
    <div class="door-frame">
      <div class="door-inner">
        <!-- Interior warm light panels -->
        <div class="door-light-top"></div>
        <div class="door-light-bottom"></div>
        <!-- Door handle -->
        <div class="door-handle"></div>
      </div>
    </div>
    <!-- Threshold line -->
    <div class="w-40 h-px bg-coffee-brown/20 mt-0"></div>
  </div>

  <!-- Text -->
  <div class="relative z-10 text-center px-6">
    <h2 class="font-serif text-cream text-5xl md:text-7xl font-normal leading-none mb-6 entrance-heading">
      Come inside.
    </h2>
    <p class="font-sans font-light text-cream/50 text-lg tracking-wide">
      The coffee is ready.
    </p>
  </div>

  <!-- GSAP placeholder note -->
  <span class="absolute bottom-8 left-1/2 -translate-x-1/2 font-sans text-xs text-cream/15 tracking-widest uppercase" aria-hidden="true">
    GSAP Door Open — ScrollTrigger
  </span>

  <!-- Transition to Story -->
  <div class="absolute bottom-0 left-0 right-0 h-48 entrance-exit pointer-events-none" aria-hidden="true"></div>

</section>

<style>
  .entrance-bg {
    background:
      radial-gradient(ellipse 35% 40% at 50% 42%, rgba(180, 110, 45, 0.14) 0%, transparent 65%),
      linear-gradient(180deg, #1a120d 0%, #241A14 50%, #1f1410 100%);
  }

  .door-glow {
    background: radial-gradient(
      ellipse 40% 50% at 50% 42%,
      rgba(210, 150, 70, 0.08) 0%,
      transparent 70%
    );
  }

  .door-frame {
    width: 140px;
    height: 220px;
    border: 1.5px solid rgba(216, 195, 165, 0.25);
    border-bottom: none;
    border-radius: 70px 70px 0 0;
    position: relative;
    padding: 8px;
  }

  .door-inner {
    width: 100%;
    height: 100%;
    border-radius: 60px 60px 0 0;
    overflow: hidden;
    position: relative;
    background: linear-gradient(
      180deg,
      rgba(200, 140, 60, 0.22) 0%,
      rgba(160, 100, 40, 0.14) 40%,
      rgba(90, 62, 43, 0.08) 100%
    );
    border: 1px solid rgba(216, 195, 165, 0.12);
  }

  .door-light-top {
    position: absolute;
    top: 10%;
    left: 15%;
    right: 15%;
    height: 45%;
    background: linear-gradient(
      180deg,
      rgba(220, 160, 80, 0.18) 0%,
      rgba(200, 130, 60, 0.08) 100%
    );
    border-radius: 50px 50px 0 0;
    border: 1px solid rgba(216, 195, 165, 0.12);
  }

  .door-light-bottom {
    position: absolute;
    bottom: 0;
    left: 15%;
    right: 15%;
    height: 40%;
    background: linear-gradient(
      180deg,
      rgba(200, 130, 60, 0.08) 0%,
      rgba(180, 110, 50, 0.14) 100%
    );
    border: 1px solid rgba(216, 195, 165, 0.10);
    border-bottom: none;
  }

  .door-handle {
    position: absolute;
    right: 18%;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(216, 195, 165, 0.4);
    box-shadow: 0 0 8px rgba(220, 160, 80, 0.3);
  }

  .entrance-heading {
    text-shadow: 0 0 40px rgba(200, 140, 60, 0.15);
    letter-spacing: -0.02em;
  }

  .entrance-exit {
    background: linear-gradient(to bottom, transparent, #F5EFE6);
  }
</style>
