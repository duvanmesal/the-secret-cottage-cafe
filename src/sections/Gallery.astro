---
import { galleryItems } from '../data/galleryItems'

const itemGradients: Record<string, string> = {
  'gallery-morning-light':    'linear-gradient(135deg, #E8C98C 0%, #C4955A 40%, #8C6035 100%)',
  'gallery-the-pour':         'linear-gradient(135deg, #5A3E2B 0%, #3d2a1e 50%, #241A14 100%)',
  'gallery-cardamom-buns':    'linear-gradient(135deg, #D4A96A 0%, #B8894A 40%, #8C6C35 100%)',
  'gallery-garden-path':      'linear-gradient(135deg, #A7B89A 0%, #6B8A62 40%, #3F5D45 100%)',
  'gallery-two-cups':         'linear-gradient(135deg, #D8C3A5 0%, #C0A882 40%, #A08060 100%)',
  'gallery-cottage-exterior': 'linear-gradient(135deg, #2d3a28 0%, #3F5D45 40%, #1e2a1a 100%)',
}
---

<section id="gallery" class="relative bg-warm-beige overflow-hidden" aria-label="Photo gallery">

  <!-- Visually-hidden heading for document outline + screen readers -->
  <!-- copy.md specifies: no written copy in gallery, images only -->
  <h2 class="sr-only">Gallery</h2>

  <div class="w-full h-px bg-coffee-brown/10" aria-hidden="true"></div>

  <!-- Gallery grid — no text header per copy spec -->
  <div class="gallery-grid max-w-6xl mx-auto px-6 md:px-12 py-10 md:py-14">
    {galleryItems.map((item) => (
      <figure
        class="gallery-item group relative overflow-hidden"
        style={`aspect-ratio: ${item.aspectRatio === 'portrait' ? '3/4' : item.aspectRatio === 'square' ? '1/1' : '4/3'}`}
      >
        <!-- Atmospheric gradient placeholder — replaced with <Image /> later -->
        <div
          class="absolute inset-0 gallery-img-inner"
          style={`background: ${itemGradients[item.id] ?? 'linear-gradient(135deg, #D8C3A5, #A08060)'}`}
          aria-hidden="true"
        ></div>

        <!-- Dark overlay on hover -->
        <div class="absolute inset-0 bg-dark-espresso/0 group-hover:bg-dark-espresso/18 transition-colors duration-500" aria-hidden="true"></div>

        <!-- Figcaption slides up from bottom -->
        <figcaption class="absolute bottom-0 left-0 right-0 px-5 py-4 gallery-caption translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out">
          <p class="font-sans text-xs font-light text-cream/85 leading-snug">
            {item.imageAlt}
          </p>
        </figcaption>

        <!-- Corner mark appears on hover -->
        <div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-cream/25 opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>

      </figure>
    ))}
  </div>

  <div class="w-full h-px bg-coffee-brown/10" aria-hidden="true"></div>

</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
  }

  .gallery-item {
    border-radius: 2px;
    cursor: pointer;
  }

  .gallery-img-inner {
    transition: transform 0.5s ease-out;
  }
  .gallery-item:hover .gallery-img-inner {
    transform: scale(1.04);
  }

  .gallery-caption {
    background: linear-gradient(to top, rgba(36, 26, 20, 0.72), transparent);
    backdrop-filter: blur(4px);
  }

  /* sr-only utility (in case Tailwind's isn't available) */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
