---
const navLinks = [
  { label: 'Our Story',       href: '#story'      },
  { label: 'The Menu',        href: '#menu'        },
  { label: 'Gallery',         href: '#gallery'     },
  { label: 'Reserve a Table', href: '#reservation' },
]
---

<footer id="footer" class="relative bg-dark-espresso overflow-hidden">

  <!-- Thin top border -->
  <div class="w-full h-px footer-border" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-6 md:px-12 pt-16 md:pt-20 pb-12">

    <div class="grid md:grid-cols-3 gap-14 md:gap-8 mb-16">

      <!-- Col 1: Logo + tagline -->
      <div>
        <a href="/" class="font-serif italic text-cream text-xl leading-tight block mb-5 hover:text-warm-beige transition-colors duration-300">
          The Secret<br />Cottage Café
        </a>
        <p class="font-serif italic text-warm-beige/50 text-base leading-relaxed max-w-xs">
          A hidden place worth finding.
        </p>
        <!-- Social icons -->
        <div class="flex items-center gap-4 mt-8">
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="social-icon group">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-cream/40 group-hover:text-rose-clay transition-colors duration-300">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <!-- Pinterest -->
          <a href="#" aria-label="Pinterest" class="social-icon group">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-cream/40 group-hover:text-rose-clay transition-colors duration-300">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.03-2.83.19-.77 1.28-5.43 1.28-5.43s-.33-.65-.33-1.62c0-1.52.88-2.66 1.97-2.66.93 0 1.38.7 1.38 1.54 0 .94-.6 2.34-.91 3.64-.26 1.09.54 1.97 1.6 1.97 1.92 0 3.4-2.02 3.4-4.95 0-2.59-1.86-4.4-4.52-4.4-3.08 0-4.89 2.31-4.89 4.7 0 .93.36 1.93.8 2.47.09.1.1.2.07.3-.08.34-.27 1.09-.3 1.24-.05.2-.17.24-.38.14-1.39-.65-2.26-2.68-2.26-4.31 0-3.51 2.55-6.74 7.35-6.74 3.86 0 6.86 2.75 6.86 6.42 0 3.83-2.41 6.9-5.76 6.9-1.13 0-2.19-.59-2.55-1.28l-.69 2.6c-.25.97-.93 2.18-1.39 2.91.05.01.1.02.15.03.45.08.91.12 1.38.12 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Navigation -->
      <div class="md:text-center">
        <p class="font-sans text-xs tracking-[0.2em] uppercase text-cream/30 mb-7">
          Navigate
        </p>
        <nav>
          <ul class="space-y-4">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class="font-sans font-light text-cream/60 text-sm hover:text-cream transition-colors duration-300 footer-link"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Col 3: Address + hours -->
      <div class="md:text-right">
        <p class="font-sans text-xs tracking-[0.2em] uppercase text-cream/30 mb-7">
          Find Us
        </p>
        <address class="not-italic">
          <p class="font-sans font-light text-cream/60 text-sm leading-relaxed mb-5">
            14 Holloway Lane<br />
            Forest Edge
          </p>
          <p class="font-sans font-light text-cream/60 text-sm leading-relaxed">
            Open Tuesday–Sunday<br />
            8am – 4pm
          </p>
        </address>
      </div>

    </div>

    <!-- Bottom row -->
    <div class="footer-bottom-border pt-8 flex flex-col md:flex-row items-center md:items-end justify-between gap-4">

      <!-- Caveat sign-off -->
      <p class="font-accent text-rose-clay/70 text-xl">
        Brewed with love in the forest.
      </p>

      <!-- Copyright -->
      <p class="font-sans text-xs text-cream/25 tracking-wide">
        © 2025 The Secret Cottage Café. All rights reserved.
      </p>

    </div>

  </div>

</footer>

<style>
  .footer-border {
    background: linear-gradient(
      to right,
      transparent,
      rgba(90, 62, 43, 0.4) 30%,
      rgba(90, 62, 43, 0.4) 70%,
      transparent
    );
  }

  .footer-bottom-border {
    border-top: 1px solid rgba(216, 195, 165, 0.08);
  }

  .footer-link {
    position: relative;
    display: inline-block;
  }
  .footer-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #C98F7A;
    transition: width 0.3s ease;
  }
  .footer-link:hover::after {
    width: 100%;
  }
</style>
