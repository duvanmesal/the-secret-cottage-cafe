---
---

<section id="story" class="relative noise-overlay bg-cream overflow-hidden">

  <!-- Top texture band -->
  <div class="w-full h-px bg-warm-beige/60" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-6 md:px-12 py-24 md:py-36">

    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">

      <!-- Left: image placeholder + decorative elements -->
      <div data-story-left class="relative">

        <!-- Main image placeholder -->
        <div class="story-image-placeholder relative overflow-hidden">
          <div class="absolute inset-0 story-image-gradient"></div>
          <!-- Decorative corner marks -->
          <div class="absolute top-4 left-4 w-5 h-5 border-t border-l border-coffee-brown/30"></div>
          <div class="absolute top-4 right-4 w-5 h-5 border-t border-r border-coffee-brown/30"></div>
          <div class="absolute bottom-4 left-4 w-5 h-5 border-b border-l border-coffee-brown/30"></div>
          <div class="absolute bottom-4 right-4 w-5 h-5 border-b border-r border-coffee-brown/30"></div>
          <!-- Placeholder label -->
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="font-sans text-xs text-coffee-brown/30 tracking-widest uppercase text-center leading-loose">
              Editorial<br />Photography
            </span>
          </div>
        </div>

        <!-- Small accent image placeholder -->
        <div class="story-accent-image absolute -bottom-8 -right-4 md:-right-8 overflow-hidden hidden md:block">
          <div class="absolute inset-0 story-accent-gradient"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="font-sans text-xs text-coffee-brown/30 tracking-widest uppercase">
              Detail
            </span>
          </div>
        </div>

        <!-- Since label -->
        <div class="mt-8 md:mt-10">
          <p class="font-accent text-rose-clay text-2xl">Everything made here, with time.</p>
        </div>

      </div>

      <!-- Right: text -->
      <div data-story-right class="relative pt-0 md:pt-8">

        <!-- Section marker -->
        <p class="font-sans text-xs tracking-[0.2em] uppercase text-soft-sage mb-10">
          Our Story
        </p>

        <!-- Pull quote -->
        <blockquote class="font-serif italic text-coffee-brown text-2xl md:text-3xl leading-snug mb-10 story-quote">
          "We didn't want to open a café. We wanted to create a place where time slows down."
        </blockquote>

        <div class="divider-warm mb-10" aria-hidden="true"></div>

        <!-- Body paragraphs -->
        <div class="space-y-6">
          <p class="font-sans font-light text-dark-espresso/75 text-base md:text-lg leading-relaxed">
            The Secret Cottage Café began as a weekend ritual — two friends, a cast-iron kettle, and a kitchen that smelled of cardamom and warm bread. What started as a private morning habit became something we felt we had to share.
          </p>
          <p class="font-sans font-light text-dark-espresso/75 text-base md:text-lg leading-relaxed">
            We found the cottage in 2018. A year of slow renovation later, we opened with six tables, a wood-burning stove, and the belief that the best coffee is the one you drink without rushing.
          </p>
          <p class="font-sans font-light text-dark-espresso/75 text-base md:text-lg leading-relaxed">
            Everything here is made by hand. The jams, the pastries, the candles, the playlists. Even the cups come from a ceramicist two villages away.
          </p>
        </div>

      </div>

    </div>

  </div>

  <!-- Bottom wave to next section -->
  <div class="w-full h-px bg-warm-beige/60" aria-hidden="true"></div>

</section>

<style>
  .story-image-placeholder {
    aspect-ratio: 4 / 5;
    background: #D8C3A5;
    border-radius: 2px;
  }

  .story-image-gradient {
    background: linear-gradient(
      135deg,
      #E8D8C4 0%,
      #D8C3A5 30%,
      #C4A882 60%,
      #A88860 100%
    );
  }

  .story-accent-image {
    width: 130px;
    height: 160px;
    border-radius: 2px;
    border: 3px solid #F5EFE6;
  }

  .story-accent-gradient {
    background: linear-gradient(135deg, #5A3E2B 0%, #3d2a1c 100%);
  }

  .story-quote {
    position: relative;
    padding-left: 1.2rem;
    border-left: 2px solid #D8C3A5;
  }
</style>
