---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../sections/Hero.astro'
import GardenPath from '../sections/GardenPath.astro'
import CottageEntrance from '../sections/CottageEntrance.astro'
import Story from '../sections/Story.astro'
import CoffeeRitual from '../sections/CoffeeRitual.astro'
import SeasonalGarden from '../sections/SeasonalGarden.astro'
import Gallery from '../sections/Gallery.astro'
import Footer from '../sections/Footer.astro'

import { menuItems, type MenuCategory } from '../data/menuItems'

const categoryOrder: MenuCategory[] = ['seasonal-special', 'espresso', 'cold']
const categoryLabels: Record<MenuCategory, string> = {
  'seasonal-special': 'Seasonal Specials',
  'espresso':         'Espresso',
  'pour-over':        'Pour-Overs',
  'cold':             'Cold Brew',
  'pastry':           'Pastries',
}
const grouped = categoryOrder.reduce<Record<string, typeof menuItems>>((acc, cat) => {
  acc[cat] = menuItems.filter(i => i.category === cat)
  return acc
}, {})
---

<Layout>
  <Nav />
  <Hero />
  <GardenPath />
  <CottageEntrance />
  <Story />
  <CoffeeRitual />

  <!-- ─── Section 6: Interactive Menu ──────────────────────────────────────
       React island (Menu.tsx) will replace this placeholder.
       Uses: React + Motion + Zustand
  ───────────────────────────────────────────────────────────────────────── -->
  <section id="menu" class="relative bg-cream">
    <div class="w-full h-px bg-warm-beige/80" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-6 md:px-12 py-24 md:py-36">

      <div class="mb-16">
        <p class="font-sans text-xs tracking-[0.2em] uppercase text-soft-sage mb-6">What we pour</p>
        <h2 class="font-serif text-coffee-brown text-5xl md:text-7xl font-normal leading-none mb-6">
          The Menu
        </h2>
        <p class="font-sans font-light text-dark-espresso/60 text-lg max-w-md">
          Everything changes with the season. These are what we're pouring today.
        </p>
      </div>

      <!-- Editorial menu list — grouped by category -->
      <div class="menu-list max-w-2xl">
        {categoryOrder.map(cat => grouped[cat]?.length > 0 && (
          <div class="menu-category mb-12 last:mb-0">

            <!-- Category header -->
            <div class="flex items-center gap-4 mb-6">
              <span class="font-sans text-xs tracking-[0.22em] uppercase text-soft-sage">
                {categoryLabels[cat]}
              </span>
              <div class="flex-1 h-px bg-warm-beige/80"></div>
            </div>

            <!-- Items -->
            <div class="space-y-0">
              {grouped[cat].map((item, idx) => (
                <div class="menu-row group">
                  <div class="menu-row-main">
                    <h3 class="menu-item-name font-serif italic text-coffee-brown text-xl font-normal leading-snug group-hover:text-dark-espresso transition-colors duration-300">
                      {item.name}
                    </h3>
                    <span class="menu-item-price font-sans text-sm text-dark-espresso/40 tracking-wide flex-shrink-0">
                      {item.price}
                    </span>
                  </div>
                  <p class="font-sans font-light text-dark-espresso/50 text-sm leading-relaxed mt-1 mb-0">
                    {item.shortDescription}
                  </p>
                  {idx < grouped[cat].length - 1 && (
                    <div class="menu-row-divider"></div>
                  )}
                </div>
              ))}
            </div>

          </div>
        ))}
      </div>

      <p class="font-accent text-rose-clay text-xl mt-14">
        Menu changes with the seasons. Ask us what's new.
      </p>

      <!-- React island placeholder note -->
      <p class="font-sans text-xs text-coffee-brown/20 tracking-widest uppercase mt-4" aria-hidden="true">
        React Island — Menu.tsx · Motion hover · Zustand selection
      </p>
    </div>
    <div class="w-full h-px bg-warm-beige/80" aria-hidden="true"></div>
  </section>

  <!-- ─── Section 7: 3D Coffee Viewer ──────────────────────────────────────
       React island (CoffeeViewer.tsx) will replace this placeholder.
       Uses: React + Spline + R3F steam
  ───────────────────────────────────────────────────────────────────────── -->
  <section id="coffee-viewer" class="relative bg-cream py-24 md:py-36">
    <div class="max-w-3xl mx-auto px-6 text-center">

      <p class="font-sans text-xs tracking-[0.2em] uppercase text-soft-sage mb-8">
        Select a drink above to explore
      </p>

      <!-- Cup viewer placeholder -->
      <div class="relative mx-auto viewer-placeholder">
        <div class="absolute inset-0 viewer-bg rounded-full" aria-hidden="true"></div>
        <div class="relative z-10 flex flex-col items-center justify-center h-full">
          <div class="viewer-cup" aria-hidden="true">
            <div class="viewer-cup-body"></div>
            <div class="viewer-cup-saucer"></div>
          </div>
          <p class="font-sans text-xs text-coffee-brown/30 tracking-widest uppercase mt-8">
            Spline 3D — Coffee Viewer
          </p>
          <p class="font-sans text-xs text-coffee-brown/20 mt-1">
            Turn me.
          </p>
        </div>
      </div>

      <p class="font-sans text-xs text-coffee-brown/20 tracking-widest uppercase mt-10" aria-hidden="true">
        React Island — CoffeeViewer.tsx · Spline + R3F Steam · Zustand
      </p>
    </div>
  </section>

  <SeasonalGarden />
  <Gallery />

  <!-- ─── Section 10: Reservation ──────────────────────────────────────────
       React island (Reservation.tsx) will replace this placeholder.
       Uses: React + Motion
  ───────────────────────────────────────────────────────────────────────── -->
  <section id="reservation" class="relative bg-cream overflow-hidden">
    <div class="w-full h-px bg-warm-beige/80" aria-hidden="true"></div>
    <div class="max-w-2xl mx-auto px-6 md:px-12 py-28 md:py-40 text-center">

      <p class="font-sans text-xs tracking-[0.2em] uppercase text-soft-sage mb-8">
        A table awaits
      </p>

      <h2 class="font-serif italic text-coffee-brown text-4xl md:text-6xl font-normal leading-tight mb-6">
        Reserve your morning.
      </h2>

      <p class="font-sans font-light text-dark-espresso/60 text-lg mb-16">
        Tables are limited. That's intentional.
      </p>

      <!-- Static form (non-functional, React island will handle it) -->
      <form class="space-y-10 text-left" aria-label="Table reservation form">

        <div class="reservation-field">
          <label class="reservation-label" for="res-name">Name</label>
          <input
            id="res-name"
            type="text"
            name="name"
            placeholder="Your name"
            autocomplete="name"
            class="reservation-input"
          />
        </div>

        <div class="reservation-field">
          <label class="reservation-label" for="res-date">Date</label>
          <input
            id="res-date"
            type="date"
            name="date"
            class="reservation-input"
          />
        </div>

        <div class="reservation-field">
          <label class="reservation-label" for="res-guests">Number of guests</label>
          <input
            id="res-guests"
            type="number"
            name="guests"
            min="1"
            max="8"
            placeholder="2"
            class="reservation-input"
          />
        </div>

        <div class="reservation-field">
          <label class="reservation-label" for="res-note">A note for us <span class="text-dark-espresso/30">(optional)</span></label>
          <textarea
            id="res-note"
            name="note"
            rows="3"
            placeholder="Dietary needs, special occasions, a kind word…"
            class="reservation-input resize-none"
          ></textarea>
        </div>

        <div class="pt-4 text-center">
          <button type="submit" class="reservation-btn">
            Reserve a Table
          </button>
          <p class="font-sans text-xs text-coffee-brown/25 tracking-widest uppercase mt-6" aria-hidden="true">
            React Island — Reservation.tsx · Motion form animations
          </p>
        </div>

      </form>

    </div>
    <div class="w-full h-px bg-warm-beige/80" aria-hidden="true"></div>
  </section>

  <Footer />
</Layout>

<style>
  /* Editorial menu list */
  .menu-list {
    width: 100%;
  }

  .menu-row {
    padding: 1.1rem 0;
    cursor: default;
  }

  .menu-row-main {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .menu-item-name {
    flex: 1;
  }

  .menu-row-divider {
    width: 100%;
    height: 1px;
    background: rgba(216, 195, 165, 0.55);
    margin-top: 1rem;
  }

  /* Viewer placeholder */
  .viewer-placeholder {
    width: min(440px, 90vw);
    height: min(440px, 90vw);
  }
  .viewer-bg {
    background: radial-gradient(
      ellipse at center,
      #E8DDD0 0%,
      #D8C3A5 60%,
      #C4A882 100%
    );
    opacity: 0.5;
  }
  .viewer-cup {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .viewer-cup-body {
    width: 80px;
    height: 68px;
    background: linear-gradient(160deg, #E8DDD0 0%, #D0B896 100%);
    border-radius: 6px 6px 14px 14px;
    border: 1.5px solid rgba(90, 62, 43, 0.15);
    box-shadow: 0 8px 24px rgba(90, 62, 43, 0.12);
    position: relative;
  }
  .viewer-cup-body::after {
    content: '';
    position: absolute;
    right: -16px;
    top: 12px;
    width: 16px;
    height: 28px;
    border: 1.5px solid rgba(90, 62, 43, 0.15);
    border-left: none;
    border-radius: 0 50% 50% 0;
  }
  .viewer-cup-saucer {
    width: 104px;
    height: 10px;
    background: linear-gradient(160deg, #E8DDD0 0%, #D0B896 100%);
    border-radius: 50%;
    border: 1.5px solid rgba(90, 62, 43, 0.12);
    margin-top: 3px;
    box-shadow: 0 4px 12px rgba(90, 62, 43, 0.08);
  }

  /* Reservation form */
  .reservation-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .reservation-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(36, 26, 20, 0.45);
  }
  .reservation-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(216, 195, 165, 0.8);
    outline: none;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1rem;
    color: #241A14;
    padding: 0.5rem 0;
    width: 100%;
    transition: border-color 0.25s ease;
  }
  .reservation-input::placeholder {
    color: rgba(36, 26, 20, 0.25);
  }
  .reservation-input:focus {
    border-bottom-color: #C98F7A;
  }

  .reservation-btn {
    display: inline-block;
    background: #C98F7A;
    color: #F5EFE6;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 1rem 2.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease;
  }
  .reservation-btn:hover {
    background: #b87d69;
    transform: translateY(-1px);
  }
  .reservation-btn:active {
    transform: translateY(0);
  }
</style>
